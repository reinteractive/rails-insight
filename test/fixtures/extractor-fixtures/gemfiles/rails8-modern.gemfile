source "https://rubygems.org"
ruby "3.3.0"

gem "rails", "~> 8.0.0"
gem "puma", ">= 5"
gem "propshaft"

# Frontend
gem "importmap-rails"
gem "turbo-rails"
gem "stimulus-rails"
gem "tailwindcss-rails"

# Database
gem "pg", "~> 1.1"
gem "redis", ">= 4.0.1"

# Auth
gem "devise"
gem "omniauth"
gem "pundit"

# Background
gem "solid_queue"
gem "solid_cache"
gem "solid_cable"
gem "mission_control-jobs"

# Search
gem "pg_search"

# Deployment
gem "kamal"
gem "thruster"

# Storage
gem "aws-sdk-s3", require: false
gem "image_processing", "~> 1.2"

# Monitoring
gem "sentry-rails"

# Admin
gem "avo"

# API
gem "jbuilder"
gem "rack-cors"

# Realtime
# ActionCable is built-in

# Jobs
gem "sidekiq"

# Payments
gem "pay"
gem "stripe"

# PDF
gem "grover"

# i18n
gem "rails-i18n"

gem "bootsnap", require: false

group :development, :test do
  gem "debug", platforms: %i[mri mingw x64_mingw]
  gem "rspec-rails"
  gem "factory_bot_rails"
  gem "faker"
  gem "rubocop-rails-omakase", require: false
  gem "brakeman", require: false
end

group :development do
  gem "web-console"
  gem "rack-mini-profiler"
  gem "spring"
  gem "annotate"
  gem "letter_opener"
  gem "bullet"
end

group :test do
  gem "capybara"
  gem "selenium-webdriver"
  gem "shoulda-matchers"
  gem "simplecov", require: false
  gem "webmock"
  gem "vcr"
end

group :production do
  gem "lograge"
end
