source "https://rubygems.org"
ruby "2.7.8"

gem "rails", "~> 6.1.0"
gem "puma", "~> 5.0"
gem "sass-rails", ">= 6"
gem "webpacker", "~> 5.0"
gem "turbolinks", "~> 5"

gem "pg", "~> 1.1"
gem "redis", "~> 4.0"

gem "devise"
gem "cancancan"

gem "sidekiq"
gem "carrierwave"
gem "mini_magick"

gem "bootsnap", ">= 1.4.4", require: false

group :development, :test do
  gem "byebug", platforms: %i[mri mingw x64_mingw]
  gem "rspec-rails"
  gem "factory_bot_rails"
end

group :development do
  gem "web-console", ">= 4.1.0"
  gem "listen", "~> 3.3"
  gem "spring"
end

group :test do
  gem "capybara", ">= 3.26"
  gem "selenium-webdriver"
  gem "database_cleaner"
end
