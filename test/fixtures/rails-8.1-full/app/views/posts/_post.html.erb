<%= turbo_frame_tag dom_id(post) do %>
  <article class="post" id="<%= dom_id(post) %>">
    <h2><%= link_to post.title, post %></h2>
    <p class="meta">
      By <%= post.user.username %> &middot; <%= time_ago_in_words(post.created_at) %> ago
    </p>
    <p><%= truncate(post.body, length: 200) %></p>

    <div class="tags">
      <% post.tag_list.each do |tag| %>
        <span class="tag"><%= tag %></span>
      <% end %>
    </div>

    <div class="actions">
      <%= render ButtonComponent.new(label: "Read More", variant: :primary) %>
      <% if policy(post).edit? %>
        <%= render ButtonComponent.new(label: "Edit", variant: :secondary) %>
      <% end %>
    </div>
  </article>
<% end %>
